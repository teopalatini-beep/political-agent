TELEGRAM_BOT_TOKEN=replace_with_bot_token
TELEGRAM_CHAT_ID=replace_with_chat_id

# Newsletter email
EMAIL_FROM=your_email@example.com
EMAIL_USER=your_email@example.com
EMAIL_PASS=replace_with_app_password
EMAIL_TO=recipient@example.com
NEWSLETTER_HOUR=8
NEWSLETTER_MINUTE=0
TZ=America/Argentina/Buenos_Aires

# Data providers
TWELVE_DATA_KEY=replace_with_twelve_data_key

# Google Drive (optional)
GOOGLE_SERVICE_ACCOUNT_KEY=/absolute/path/to/service-account.json
GOOGLE_DRIVE_FOLDER_ID=replace_with_folder_id

# Runtime behavior
DISABLE_BOT=false
HEARTBEAT_INTERVAL_MS=60000
DEDUP_WINDOW_HOURS=48
DEDUP_NEWSLETTER_ONLY=true
MAX_ITEMS_PER_SOURCE_REGION=3
ALERTS_LIMIT=6
